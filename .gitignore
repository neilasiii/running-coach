# Environment configuration (contains API keys and credentials)
.env

# Discord bot token
config/discord_bot.env

# Garmin Connect credentials
# Environment variables: GARMIN_EMAIL and GARMIN_PASSWORD
# Or config file: config/.garmin_config.json
# Tokens stored in ~/.garminconnect/ by garminconnect library
.garmin_credentials.json
config/.garmin_config.json
config/.garmin_session.json

# Calendar URLs (may contain private calendar links)
config/calendar_sources.json

# Calendar export config (may contain custom settings)
config/calendar_export.json

# Generated calendar export files
data/calendar/*.ics
!data/calendar/.gitkeep

# Cache backups (created automatically on corruption or before updates)
*.json.bak

# Note: data/health/health_data_cache.json is committed for cross-session persistence

# Garmin raw exports (manual exports from Garmin Connect)
health_connect_export/

# Test/development files (archived)
data/archive/test_workouts/

# Archived scripts (unused variants)
bin/archive/

# Log files
data/*.log
data/ai_validation.log

# Generated HTML reports (regenerated on demand)
data/morning_report_detailed.html
data/test_morning_report.html

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
config/gemini_api.env
