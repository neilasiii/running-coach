# =============================================================================
# Running Coach Service Configuration
# =============================================================================
# Copy this file to .env and fill in your values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your API keys and settings
#   docker-compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Choose which AI provider to use: claude, openai, gemini, or ollama
AI_PROVIDER=claude

# Claude/Anthropic API Key
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Ollama Configuration (for local LLMs)
# If using docker-compose with ollama service, use: http://ollama:11434
# If using external Ollama, use: http://your-ollama-host:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:latest

# -----------------------------------------------------------------------------
# Garmin Connect Integration (Optional)
# -----------------------------------------------------------------------------
# Required only if you want to sync health data from Garmin Connect
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# -----------------------------------------------------------------------------
# Flask Server Configuration
# -----------------------------------------------------------------------------
# Flask environment: development or production
FLASK_ENV=production

# Enable debug mode (true/false) - should be false in production
DEBUG=false

# Server port (default: 5000)
PORT=5000

# Server host (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0
