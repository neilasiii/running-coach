version: '3.8'

services:
  running-coach:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: running-coach
    restart: unless-stopped
    ports:
      - "5000:5000"
    environment:
      # AI Provider Selection (claude, openai, gemini, ollama)
      - AI_PROVIDER=${AI_PROVIDER:-claude}

      # Claude/Anthropic Configuration
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

      # OpenAI Configuration
      - OPENAI_API_KEY=${OPENAI_API_KEY}

      # Google Gemini Configuration
      - GOOGLE_API_KEY=${GOOGLE_API_KEY}

      # Ollama Configuration (for local LLMs)
      - OLLAMA_HOST=${OLLAMA_HOST:-http://ollama:11434}
      - OLLAMA_MODEL=${OLLAMA_MODEL:-llama3.1:latest}

      # Garmin Connect Credentials (for health data sync)
      - GARMIN_EMAIL=${GARMIN_EMAIL}
      - GARMIN_PASSWORD=${GARMIN_PASSWORD}

      # Flask Configuration
      - FLASK_ENV=${FLASK_ENV:-production}
      - PORT=5000
      - HOST=0.0.0.0
      - DEBUG=${DEBUG:-false}

    volumes:
      # Persist athlete data
      - ./data:/app/data
      # Persist agent configurations
      - ./.claude:/app/.claude
      # Persist config
      - ./config:/app/config

    networks:
      - running-coach-network

    healthcheck:
      test: ["CMD", "python", "-c", "import requests; requests.get('http://localhost:5000/api/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # Optional: Include Ollama for local LLM support
  ollama:
    image: ollama/ollama:latest
    container_name: ollama
    restart: unless-stopped
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    networks:
      - running-coach-network
    profiles:
      - ollama

networks:
  running-coach-network:
    driver: bridge

volumes:
  ollama_data:
    driver: local
